[Unit]
Description=litesoup agent — metrics and command execution API
Documentation=https://github.com/litesoup/litesoup-dashboard
After=network.target

[Service]
ExecStart=/usr/lib/litesoup/agent/litesoup-agent --port=7777
# root required: litesoup CLI commands manage Apache/PHP-FPM/MariaDB services
User=root
Restart=on-failure
RestartSec=5s
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
